<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="product_product_form_inherit_ecommerce_shop" model="ir.ui.view">
        <field name="name">product.product.view.form.inherit.ecommerce.shop</field>
        <field name="model">product.product</field>
        <field name="inherit_id" ref="product.product_normal_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//page[@name='sales']//group[@name='description']" position="after">
                <group string="ECOMMERCE SHOP" name="ecommerce">
                    <field name="is_published"/>
                </group>
            </xpath>
        </field>
    </record>
</odoo>
