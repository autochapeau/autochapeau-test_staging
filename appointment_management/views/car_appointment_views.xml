<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record id="car_appointment_view_search" model="ir.ui.view">
        <field name="name">car.appointment.search</field>
        <field name="model">car.appointment</field>
        <field name="arch" type="xml">
            <search>
                <field
                    name="name"
                    filter_domain="['|', ('name', 'ilike', self), ('partner_phone_search', 'ilike', self)]"
                />
                <field name="partner_id" />
                <field name="vehicle_id" />
                <field
                    name="partner_phone_search"
                    string="Phone / Mobile"
                    filter_domain="[('partner_phone_search', 'ilike', self)]"
                />
                <field name="branch_id" />
                <filter
                    name="waiting_appointments"
                    string="Waiting Appointments"
                    domain="[('state', '=', 'waiting'), ('start_date', '&gt;=', datetime.datetime.now())]"
                />
                <filter
                    name="confirmed_appointments"
                    string="Confirmed Appointments"
                    domain="[('state', '=', 'confirmed')]"
                />
                <filter
                    name="cancelled_appointments"
                    string="Cancelled Appointments"
                    domain="[('state', '=', 'cancelled')]"
                />
                <filter string="Archived" name="inactive" domain="[('active', '=', False)]" />
            </search>
        </field>
    </record>
    <record id="car_appointment_view_tree" model="ir.ui.view">
        <field name="name">car.appointment.tree</field>
        <field name="model">car.appointment</field>
        <field name="arch" type="xml">
            <tree js_class="appointment_dashboard_list">
                <field name="name" />
                <field name="partner_id" />
                <field name="vehicle_id" />
                <field name="branch_id" />
                <field name="vehicle_size" />
                <field name="appointment_slot_id" />
                <field name="sale_order_id" />
                <field name="service_ids" widget="many2many_tags" />
                <field
                    name="state"
                    widget="badge"
                    decoration-warning="state == 'waiting'"
                    decoration-success="state == 'confirmed'"
                />
            </tree>
        </field>
    </record>
    <record id="car_appointment_view_calendar" model="ir.ui.view">
        <field name="name">car.appointment.calendar</field>
        <field name="model">car.appointment</field>
        <field name="arch" type="xml">
            <calendar
                create="false"
                event_open_popup="false"
                string="Appointment Slots"
                date_start="start_date"
                date_stop="finish_date"
                color="state"
            >
                <field name="start_date" />
                <field name="finish_date" />
                <field name="vehicle_id" context="{'form_view_ref': 'cars_management.fleet_vehicle_view_form'}" />
                <field name="vehicle_size" />
                <field name="service_ids" widget="many2many_tags" />
            </calendar>
        </field>
    </record>

    <record id='car_appointment_view_form' model='ir.ui.view'>
        <field name="name">car.appointment.form</field>
        <field name="model">car.appointment</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button
                        name="action_done"
                        string="Confirm"
                        type="object"
                        class="oe_highlight"
                        invisible="state != 'waiting'"
                    />
                    <button name="action_cancel" string="Cancel" type="object" invisible="state != 'waiting'" />
                    <button
                        name="action_edit_appointment"
                        string="Edit Appointment"
                        type="object"
                        class="btn-warning"
                        confirm="Are you sure you want to proceed?"
                        invisible="state != 'confirmed'"
                    />
                    <button
                        name="action_cancel_appointment"
                        string="Cancel Appointment"
                        type="object"
                        class="btn-danger"
                        confirm="Are you sure you want to proceed?"
                        invisible="state != 'confirmed'"
                    />
                    <field name="state" widget="statusbar" statusbar_visible="waiting,confirmed" />
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="name" invisible="id == False" />
                        </group>
                    </group>
                    <group>
                        <group string="Customer information">
                            <field name="partner_id" readonly="state != 'waiting'" />
                            <field name="partner_phone" />
                            <field name="partner_email" />
                            <field name="branch_id" />
                        </group>
                        <group string="Car information">
                            <field
                                name="vehicle_id"
                                context="{'form_view_ref': 'cars_management.fleet_vehicle_view_form'}"
                                readonly="state != 'waiting'"
                            />
                            <field name="vehicle_license_plate" />
                            <field name="vehicle_vin_sn" />
                            <field name="vehicle_color_id" />
                            <field name="vehicle_size" />
                        </group>
                        <group string="Appointment information">
                            <field
                                name="appointment_slot_id"
                                options="{'no_create': True, 'no_open': True}"
                                readonly="state != 'waiting'"
                            />
                            <field name="company_id" readonly="state != 'waiting'" />
                            <field name="sale_order_id"/>
                        </group>
                        <group string="Additional information">
                            <field name="maintenance_slot_id" readonly="state != 'waiting'" />
                            <field name="car_transportation_service" readonly="state != 'waiting'" />
                            <field
                                name="car_transportation_date"
                                invisible="car_transportation_service == False"
                                readonly="state != 'waiting'"
                            />
                        </group>
                    </group>
                    <notebook>
                        <page name="services" string="Services">
                            <group>
                                <field colspan="2" nolabel="1" name="service_ids" readonly="state != 'waiting'">
                                    <tree editable="top">
                                        <field name="product_id" />
                                    </tree>
                                </field>
                            </group>
                        </page>
                        <page name="products" string="Products">
                            <group>
                                <field colspan="2" nolabel="1" name="product_ids" readonly="state != 'waiting'">
                                    <tree editable="top">
                                        <field name="product_id" />
                                        <field name="quantity" />
                                    </tree>
                                </field>
                            </group>
                        </page>
                    </notebook>
                </sheet>
                <div class="oe_chatter">
                     <field name="message_follower_ids" />
                     <field name="activity_ids" />
                     <field name="message_ids" />
                </div>
            </form>
        </field>
    </record>

    <record id='car_appointment_action' model='ir.actions.act_window'>
        <field name="name">Appointments</field>
        <field name="res_model">car.appointment</field>
        <field name="view_mode">tree,calendar,form</field>
    </record>


    <menuitem
        id="car_appointment_menu"
        parent="car_appointment_menu_root"
        action="car_appointment_action"
        sequence="10"
    />

</odoo>
