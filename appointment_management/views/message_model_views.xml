<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
        <record id="message_model_car_appointment_action" model="ir.actions.server">
            <field name="name">Message Models</field>
            <field name="model_id" ref="infinito_sms.model_message_model" />
            <field name="state">code</field>
            <field name="code">
                action = env['message.model'].open_form_with_car_appointment()
            </field>
        </record>

    <menuitem
        name="Message Models"
        id="message_models_appointment_menu"
        parent="car_appointment_menu_root"
        action="message_model_car_appointment_action"
        sequence="5"
    />
</odoo>
