<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <record id="product_pricelist_view_view_inherit_appointment_management" model="ir.ui.view">
        <field name="name">product.pricelist.view.inherit</field>
        <field name="model">product.pricelist</field>
        <field name="inherit_id" ref="product.product_pricelist_view" />
        <field name="arch" type="xml">
           <sheet position="before">
           <header>
                <button
                        name="action_apply_pricelist_discount"
                        string="Apply Pricelist Discount"
                        type="object"
                        class="btn-primary"
                    />
           </header>
           </sheet>
        </field>
    </record>
</odoo>
