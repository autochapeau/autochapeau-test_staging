#. module: appointment_management
#: model:mail.template,body_html:appointment_management.email_template_appointment_confirmation
msgid ""
"<div style=\"margin: 0px; padding: 0px; font-family: sans-serif;\">\n"
"                <p>\n"
"                    Dear<t t-out=\"object.partner_id.name or 'Customer'\"></t>,\n"
"                </p>\n"
"\n"
"                <p>\n"
"                    Your appointment\n"
"                    <strong>\n"
"                        <t t-out=\"object.name\"></t>\n"
"                    </strong>\n"
"                    has been confirmed.\n"
"                </p>\n"
"\n"
"                <p>\n"
"                    <strong>Appointment Details:</strong>\n"
"                </p>\n"
"                <ul>\n"
"                    <li>Date:\n"
"                        <t t-out=\"format_date(object.start_date)\"></t>\n"
"                    </li>\n"
"                    <li>Time:\n"
"                        <t t-out=\"format_time(object.start_date)\"></t>\n"
"                    </li>\n"
"                    <li>Agency:\n"
"                        <t t-out=\"object.company_id.name\"></t>\n"
"                    </li>\n"
"                    <li>Location:\n"
"                        <t t-out=\"object.company_id.partner_id.contact_address or ''\"></t>\n"
"                    </li>\n"
"                </ul>\n"
"\n"
"                <p>\n"
"                    <strong>Vehicle:</strong>\n"
"                </p>\n"
"                <ul>\n"
"                    <li>Model:\n"
"                        <t t-out=\"object.vehicle_id.model_id.name or ''\"></t>\n"
"                    </li>\n"
"                    <li>License Plate:\n"
"                        <t t-out=\"object.vehicle_license_plate\"></t>\n"
"                    </li>\n"
"                    <li>VIN:\n"
"                        <t t-out=\"object.vehicle_vin_sn\"></t>\n"
"                    </li>\n"
"                    <li>Color:\n"
"                        <t t-out=\"object.vehicle_color_id.name or 'N/A'\"></t>\n"
"                    </li>\n"
"                    <li>Size:\n"
"                        <t t-out=\"object.vehicle_size or 'N/A'\"></t>\n"
"                    </li>\n"
"                </ul>\n"
"\n"
"\n"
"                <t t-if=\"object.sale_order_id\">\n"
"                    <p>\n"
"                        <strong>Selected Services:</strong>\n"
"                    </p>\n"
"                    <ul>\n"
"                        <t t-foreach=\"object.sale_order_id.order_line\" t-as=\"line\">\n"
"                            <t t-if=\"line.product_id.detailed_type == 'service'\">\n"
"                                <li>\n"
"                                    <strong>\n"
"                                        <t t-out=\"line.product_id.name\"></t>\n"
"                                    </strong>\n"
"                                    <br>\n"
"                                    Unit Price:\n"
"                                    <t t-out=\"line.price_unit\"></t>\n"
"                                    <span t-esc=\"object.sale_order_id.currency_id.name\"></span>\n"
"                                    <br>\n"
"                                    Quantity:\n"
"                                    <t t-out=\"line.product_uom_qty\"></t>\n"
"                                    <br>\n"
"                                    Discount:<t t-out=\"line.discount or 0\"></t>%\n"
"                                    <br>\n"
"                                    Taxes:\n"
"                                    <t t-if=\"line.tax_id\">\n"
"                                        <span t-out=\"', '.join(map(lambda x: (x.description or x.name), line.tax_id))\"></span>\n"
"\n"
"\n"
"                                    </t>\n"
"                                    <t t-else=\"\">\n"
"                                        No Tax\n"
"                                    </t>\n"
"\n"
"                                    <br>\n"
"                                    Subtotal:\n"
"                                    <t t-out=\"line.price_subtotal\"></t>\n"
"                                    <span t-esc=\"object.sale_order_id.currency_id.name\"></span>\n"
"                                    <br>\n"
"                                    Total with Tax:\n"
"                                    <t t-out=\"line.price_total\"></t>\n"
"                                    <span t-esc=\"object.sale_order_id.currency_id.name\"></span>\n"
"                                    <br>\n"
"                                </li>\n"
"                            </t>\n"
"                        </t>\n"
"                    </ul>\n"
"                </t>\n"
"                <t t-if=\"object.sale_order_id\">\n"
"                    <p>\n"
"                        <strong>Products:</strong>\n"
"                    </p>\n"
"                    <ul>\n"
"                        <t t-foreach=\"object.sale_order_id.order_line\" t-as=\"line\">\n"
"                            <t t-if=\"line.product_id.detailed_type == 'product'\">\n"
"                                <li>\n"
"                                    <strong>\n"
"                                        <t t-out=\"line.product_id.name\"></t>\n"
"                                    </strong>\n"
"                                    <br>\n"
"                                    Unit Price:\n"
"                                    <t t-out=\"line.price_unit\"></t>\n"
"                                    <span t-esc=\"object.sale_order_id.currency_id.name\"></span>\n"
"                                    <br>\n"
"                                    Quantity:\n"
"                                    <t t-out=\"line.product_uom_qty\"></t>\n"
"                                    <br>\n"
"                                    Discount:<t t-out=\"line.discount or 0\"></t>%\n"
"                                    <br>\n"
"                                    Taxes:\n"
"                                    <t t-if=\"line.tax_id\">\n"
"                                        <span t-out=\"', '.join(map(lambda x: (x.description or x.name), line.tax_id))\"></span>\n"
"\n"
"\n"
"                                    </t>\n"
"                                    <t t-else=\"\">\n"
"                                        No Tax\n"
"                                    </t>\n"
"\n"
"                                    <br>\n"
"                                    Subtotal:\n"
"                                    <t t-out=\"line.price_subtotal\"></t>\n"
"                                    <span t-esc=\"object.sale_order_id.currency_id.name\"></span>\n"
"                                    <br>\n"
"                                    Total with Tax:\n"
"                                    <t t-out=\"line.price_total\"></t>\n"
"                                    <span t-esc=\"object.sale_order_id.currency_id.name\"></span>\n"
"                                    <br>\n"
"                                </li>\n"
"                            </t>\n"
"                        </t>\n"
"                    </ul>\n"
"                </t>\n"
"                <t t-if=\"object.sale_order_id\">\n"
"                    <p>\n"
"                        <strong>Payment Details:</strong>\n"
"                    </p>\n"
"                    <ul>\n"
"                        <li>Total:\n"
"                            <t t-out=\"object.sale_order_id.amount_total\"></t>\n"
"                            <span t-esc=\"object.sale_order_id.currency_id.name\"></span>\n"
"                        </li>\n"
"                        <li>Taxes:\n"
"                            <t t-out=\"object.sale_order_id.amount_tax\"></t>\n"
"                            <span t-esc=\"object.sale_order_id.currency_id.name\"></span>\n"
"                        </li>\n"
"\n"
"                        <t t-if=\"object.sale_order_id.payment_term_id\">\n"
"                            <li>Payment Terms:\n"
"                                <t t-out=\"object.sale_order_id.payment_term_id.name\"></t>\n"
"                            </li>\n"
"                        </t>\n"
"\n"
"                        <t t-if=\"object.sale_order_id.invoice_ids\">\n"
"                            <li>Payments Used:\n"
"                                <ul>\n"
"                                    <t t-foreach=\"object.sale_order_id.invoice_ids\" t-as=\"pay\">\n"
"                                        <li>\n"
"                                            <t t-out=\"pay.payment_method_id.name or 'Manual'\"></t>\n"
"                                            -\n"
"                                            <t t-out=\"pay.amount\"></t>\n"
"                                            <span t-esc=\"object.sale_order_id.currency_id.name\"></span>\n"
"                                        </li>\n"
"                                    </t>\n"
"                                </ul>\n"
"                            </li>\n"
"                        </t>\n"
"\n"
"                        <t t-if=\"object.partner_id.loyalty_balance\">\n"
"                            <li>Loyalty Points Earned:\n"
"                                <t t-out=\"object.partner_id.loyalty_balance\"></t>\n"
"                            </li>\n"
"                        </t>\n"
"\n"
"                        <t t-if=\"object.sale_order_id.donation_amount\">\n"
"                            <li>Donation:\n"
"                                <t t-out=\"object.sale_order_id.donation_amount\"></t>\n"
"                            </li>\n"
"                        </t>\n"
"                    </ul>\n"
"                </t>\n"
"\n"
"                <p>Thank you for your trust.<br>We look forward to seeing you soon!\n"
"                </p>\n"
"\n"
"                <p>Best regards,\n"
"                    <br>\n"
"                    <t t-out=\"object.company_id.name\"></t>\n"
"                </p>\n"
"            </div>\n"
"        "
msgstr ""
