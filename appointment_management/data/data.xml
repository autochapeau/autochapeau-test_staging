<odoo noupdate="1">
    <record id="car_appointment_seq" model="ir.sequence">
        <field name="name">Car appointment</field>
        <field name="code">car.appointment.seq</field>
        <field name="prefix">APP</field>
        <field name="padding">5</field>
        <field name="number_next">1</field>
        <field name="number_increment">1</field>
        <field name="company_id" eval="False" />
    </record>
    <!-- Cron to notify customers about upcoming appointments -->
    <record id="ir_cron_notify_customers_upcoming_appointments" model="ir.cron">
        <field name="name">Notify customers about upcoming appointments</field>
        <field name="model_id" ref="model_car_appointment" />
        <field name="state">code</field>
        <field name="code">model._notify_customers_upcoming_appointments()</field>
        <field name="interval_number">1</field>
        <field name="interval_type">days</field>
        <field name="numbercall">-1</field>
        <field name="active" eval="True" />
        <field name="doall" eval="False" />
    </record>
</odoo>
