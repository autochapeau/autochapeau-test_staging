<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <record model="ir.module.category" id="module_category_appointment_management">
        <field name="name">Appointments</field>
        <field name="sequence">45</field>
    </record>

    <!-- Groups-->
    <record id="group_appointment_officer" model="res.groups">
        <field name="name">Appointment Branch Employee</field>
        <field name="category_id" ref="module_category_appointment_management" />
        <field name="implied_ids" eval="[(4, ref('base.group_user'))]" />
    </record>
    <record id="group_appointment_manager" model="res.groups">
        <field name="name">Appointments Branch Manager</field>
        <field name="category_id" ref="module_category_appointment_management" />
        <field name="implied_ids" eval="[(4, ref('group_appointment_officer'))]" />
    </record>
    <record id="group_appointment_viewer_all" model="res.groups">
        <field name="name">View all branches appointments</field>
        <field name="category_id" ref="module_category_appointment_management" />
        <field name="implied_ids" eval="[(4, ref('base.group_user'))]" />
    </record>
    <!--  Rules  -->
    <record id="car_appointment_slot_multi_company_rule" model="ir.rule">
        <field name="name">Appointment slot multi-company</field>
        <field name="model_id" ref="model_car_appointment_slot" />
        <field name="domain_force">['&amp;', ('department_ids', 'in', [user.employee_id.branch_id.id]), '|', ('company_id', 'in', company_ids), ('company_id', '=', False)]</field>
        <field name="groups" eval="[(4, ref('appointment_management.group_appointment_officer'))]" />
    </record>
    <record id="car_appointment_multi_company_rule" model="ir.rule">
        <field name="name">Appointment multi-company</field>
        <field name="model_id" ref="model_car_appointment" />
        <field name="domain_force">['&amp;',('branch_id', '=', user.employee_id.branch_id.id),'|',('company_id', 'in', company_ids),('company_id', '=', False)]</field>
        <field name="groups" eval="[(4, ref('appointment_management.group_appointment_officer'))]" />
    </record>
    <record id="car_appointment_slot_exclude_manager_rule" model="ir.rule">
        <field name="name">Exclude Appointment Slot Multi-Company for Manager</field>
        <field name="model_id" ref="model_car_appointment_slot" />
        <field name="domain_force">[(1,'=',1)]</field>
        <field name="groups" eval="[(4, ref('appointment_management.group_appointment_manager')), (4, ref('appointment_management.group_appointment_viewer_all'))]" />
    </record>
    <record id="car_appointment_exclude_manager_rule" model="ir.rule">
        <field name="name">Exclude Appointment Multi-Company for Manager</field>
        <field name="model_id" ref="model_car_appointment" />
        <field name="domain_force">[(1,'=',1)]</field>
        <field name="groups" eval="[(4, ref('appointment_management.group_appointment_manager')), (4, ref('appointment_management.group_appointment_viewer_all'))]" />
    </record>

</odoo>
