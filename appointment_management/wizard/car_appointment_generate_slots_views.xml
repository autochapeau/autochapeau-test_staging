<?xml version="1.0" encoding="UTF-8" ?>
<odoo>

    <record id="car_appointment_generate_slots_view_form" model="ir.ui.view">
        <field name="name">car.appointment.generate.slots.view.form</field>
        <field name="model">car.appointment.generate.slots</field>
        <field name="arch" type="xml">
            <form>
                <sheet>

                    <group>
                        <field name="branch_ids" style="width: 100%; min-width: 300px;" widget="many2many_tags"/>
                    </group>
                    <group>
                        <group>
                            <field name="date_from" />
                            <field name="date_to" />
                            <field name="duration" />
                            <field name="capacity" />
                            <field name="resource_calendar_id" />
                        </group>
                    </group>

                    <footer>
                        <button string="Generate Slots" name="action_generate" type="object" class="btn-primary" />
                        <button string="Cancel" class="btn-secondary" special="cancel" />
                    </footer>
                </sheet>
            </form>
        </field>
    </record>

</odoo>
