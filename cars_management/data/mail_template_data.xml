<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <record id="email_template_car_checkin" model="mail.template">
        <field name="name">Car check-in</field>
        <field name="model_id" ref="cars_management.model_car_checkin" />
        <field name="subject">Car Checkout Ref {{ object.name or 'n/a' }}</field>
        <field name="email_from">{{ (object.employee_id.email_formatted or object.company_id.email_formatted or
            user.email_formatted) }}
        </field>
        <field name="partner_to">{{ object.partner_id.id }}</field>
        <field name="body_html" type="html">
            <div style="margin: 0px; padding: 0px;">
                <p style="margin: 0px; padding: 0px; font-size: 13px;">
                    Hello,
                    <br />
                    Your car check-in
                    <span style="font-weight: bold;" t-out="object.name or ''" />
                    is ready for
                    review.
                    <br />
                </p>
            </div>
        </field>
        <field name="report_template_ids" eval="[(4, ref('cars_management.action_report_checkin'))]" />
        <field name="lang">{{ object.partner_id.lang }}</field>
        <field name="auto_delete" eval="True" />
    </record>
    <record id="email_template_car_checkout" model="mail.template">
        <field name="name">Car check-in</field>
        <field name="model_id" ref="cars_management.model_car_checkout" />
        <field name="subject">Car Check-in Ref {{ object.name or 'n/a' }}</field>
        <field name="email_from">{{ (object.employee_id.email_formatted or object.company_id.email_formatted or
            user.email_formatted) }}
        </field>
        <field name="partner_to">{{ object.partner_id.id }}</field>
        <field name="body_html" type="html">
            <div style="margin: 0px; padding: 0px;">
                <p style="margin: 0px; padding: 0px; font-size: 13px;">
                    Hello,
                    <br />
                    Your car check-out
                    <span style="font-weight: bold;" t-out="object.name or ''" />
                    is ready for
                    review.
                    <br />
                </p>
            </div>
        </field>
        <field name="report_template_ids" eval="[(4, ref('cars_management.action_report_checkout'))]" />
        <field name="lang">{{ object.partner_id.lang }}</field>
        <field name="auto_delete" eval="True" />
    </record>
</odoo>
