<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- groups -->
    <record model="ir.module.category" id="module_category_cars_management">
        <field name="name">Cars management</field>
        <field name="sequence">45</field>
    </record>

    <record id="group_cars_management_branch_employee" model="res.groups">
        <field name="name">Cars Management Branch Employee</field>
        <field name="category_id" ref="cars_management.module_category_cars_management"/>
        <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
    </record>

    <record id="group_cars_management_viewer_all" model="res.groups">
        <field name="name">View All Car Orders</field>
        <field name="category_id" ref="cars_management.module_category_cars_management"/>
        <field name="implied_ids" eval="[(4, ref('cars_management.group_cars_management_branch_employee'))]"/>
    </record>

    <!-- Branch Manager -->
    <record id="rule_branch_manager_all_car_check_ins" model="ir.rule">
        <field name="name">Branch Manager All Car Check Ins</field>
        <field name="model_id" ref="cars_management.model_car_checkin"/>
        <field name="groups" eval="[(4, ref('cars_management.group_cars_management_viewer_all'))]"/>
        <field name="domain_force">[(1,'=',1)]</field>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="True"/>
        <field name="perm_create" eval="True"/>
        <field name="perm_unlink" eval="True"/>
    </record>
    <record id="rule_branch_manager_all_car_check_outs" model="ir.rule">
        <field name="name">Branch Manager All Car Check Outs</field>
        <field name="model_id" ref="cars_management.model_car_checkout"/>
        <field name="groups" eval="[(4, ref('cars_management.group_cars_management_viewer_all'))]"/>
        <field name="domain_force">[(1,'=',1)]</field>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="True"/>
        <field name="perm_create" eval="True"/>
        <field name="perm_unlink" eval="True"/>
    </record>

    <!-- Branch Employee -->
    <record id="rule_branch_employee_assigned_car_check_in" model="ir.rule">
        <field name="name">Branch Employee Assigned Car Check in</field>
        <field name="model_id" ref="cars_management.model_car_checkin"/>
        <field name="groups" eval="[(4, ref('cars_management.group_cars_management_branch_employee'))]"/>
        <field name="domain_force">[("branch_id", "=", user.employee_id.branch_id.id)]</field>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="True"/>
        <field name="perm_create" eval="True"/>
        <field name="perm_unlink" eval="True"/>
    </record>
    <record id="rule_branch_employee_assigned_car_check_out" model="ir.rule">
        <field name="name">Branch Employee Assigned Car Check Out</field>
        <field name="model_id" ref="cars_management.model_car_checkout"/>
        <field name="groups" eval="[(4, ref('cars_management.group_cars_management_branch_employee'))]"/>
        <field name="domain_force">[("branch_id", "=", user.employee_id.branch_id.id)]</field>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="True"/>
        <field name="perm_create" eval="True"/>
        <field name="perm_unlink" eval="True"/>
    </record>
</odoo>
