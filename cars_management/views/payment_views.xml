<?xml version="1.0" encoding="utf-8" ?>
<odoo>

    <record id="transaction_form_inherit_cars_management" model="ir.ui.view">
        <field name="name">payment.transaction.form.inherit.cars_management</field>
        <field name="model">payment.transaction</field>
        <field name="inherit_id" ref="payment.payment_transaction_form" />
        <field name="arch" type="xml">
            <group name="transaction_partner" position="after">
                <group name="donation_details" string="Donation Details">
                    <group>
                        <field name="donation_amount" />
                        <field name="donation_move_id" />
                    </group>
                    <group>
                        <field name="wallet_amount" />
                    </group>
                </group>
            </group>
        </field>
    </record>

</odoo>
