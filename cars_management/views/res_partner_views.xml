<?xml version="1.0" encoding="UTF-8" ?>
<odoo>

    <record id="view_partner_form" model="ir.ui.view">
        <field name="name">res.partner.form.inherit</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_form" />
        <field name="arch" type="xml">
            <field name="website" position="before">
                <field name="birthdate" />
                <field name="partner_type" />
                <field name="source_id" />
            </field>
            <field name="mobile" position="attributes">
                <attribute name="required">1</attribute>
            </field>
            <xpath expr="//div[hasclass('oe_title')]/h1" position="after">
                <field name="membership_id" invisible="1"/>
                <field name="membership_badge" nolabel="1"
                       invisible="not membership_id"/>
            </xpath>
            <div name="button_box" position="inside">
                <button
                    name="action_open_cars"
                    class="oe_stat_button"
                    icon="fa-car"
                    invisible="cars_count == 0"
                    context="{'active_test': False}"
                    type="object"
                >
                    <field name="cars_count" widget="statinfo" string="Car" />
                </button>
            </div>
        </field>
    </record>

    <record id="crm_lead_partner_kanban_view_inherit_cars_management" model="ir.ui.view">
        <field name="name">res.partner.kanban.saleorder.inherit</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="sale.crm_lead_partner_kanban_view" />
        <field name="arch" type="xml">
            <xpath expr="//a[@data-name='action_view_sale_order']/span/i" position="attributes">
                 <attribute name="style">display: none;</attribute>
            </xpath>
              <xpath expr="//a[@data-name='action_view_sale_order']/span/i" position="after">
            <img
                    src="/cars_management/static/description/Saudi_Riyal.png"
                    alt="Sale Icon"
                    class="img-fluid me-1"
                    style="height: 12px;"
                />
        </xpath>
        </field>
    </record>

</odoo>
