<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <record id="res_config_settings_view_form_inherit_cars_management" model="ir.ui.view">
        <field name="name">res.config.settings.inherit.cars_management</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="account.res_config_settings_view_form" />
        <field name="arch" type="xml">
            <xpath expr="//block[@id='default_accounts']" position="inside">
                <div class="col-12 col-lg-6 o_setting_box">
                    <div class="o_setting_left_pane" />
                    <div class="o_setting_right_pane">
                        <span class="o_form_label">Donation Accounts</span>
                        <div class="content-group">
                            <div class="row mt8">
                                <label for="donation_debit_account_id" class="col-lg-5 o_light_label" />
                                <field name="donation_debit_account_id" />
                            </div>
                            <div class="row mt8">
                                <label for="donation_credit_account_id" class="col-lg-5 o_light_label" />
                                <field name="donation_credit_account_id" />
                            </div>
                            <div class="row mt8">
                                <label for="donation_journal_id" class="col-lg-5 o_light_label" />
                                <field name="donation_journal_id" />
                            </div>
                        </div>
                    </div>
                </div>
            </xpath>
        </field>
    </record>
</odoo>
