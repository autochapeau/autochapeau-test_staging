<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record id='fleet_vehicle_model_view_form' model='ir.ui.view'>
        <field name="name">fleet.vehicle.model.form.inherit.cars_management</field>
        <field name="model">fleet.vehicle.model</field>
        <field name="inherit_id" ref="fleet.fleet_vehicle_model_view_form" />
        <field name="arch" type="xml">
            <field name="seats" position="before">
                <field name="size" />
            </field>
        </field>
    </record>

    <record id='fleet_vehicle_model_view_tree' model='ir.ui.view'>
        <field name="name">fleet.vehicle.model.tree.inherit.cars_management</field>
        <field name="model">fleet.vehicle.model</field>
        <field name="inherit_id" ref="fleet.fleet_vehicle_model_view_tree" />
        <field name="arch" type="xml">
            <field name="name" position="after">
                <field name="size" />
            </field>
        </field>
    </record>

</odoo>
