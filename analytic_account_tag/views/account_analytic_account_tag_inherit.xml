<odoo>
    <record id="view_account_analytic_account_form_inherit_tags" model="ir.ui.view">
        <field name="name">account.analytic.account.form.inherit.tags</field>
        <field name="model">account.analytic.account</field>
        <field name="inherit_id" ref="analytic.view_account_analytic_account_form"/>
        <field name="arch" type="xml">
            <field name="name" position="after">
                <group>
                    <field name="tag_ids" widget="many2many_tags" style="max-width: 200px; min-width: 100px; width: 200px;"/>
                </group>
            </field>
        </field>
    </record>
</odoo>
