<odoo>
    <record id="view_analytic_account_tag_tree" model="ir.ui.view">
        <field name="name">analytic.account.tag.tree</field>
        <field name="model">analytic.account.tag</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name"/>
                <field name="color" widget="color_picker"/>
                <field name="active"/>
            </tree>
        </field>
    </record>

    <record id="view_analytic_account_tag_form" model="ir.ui.view">
        <field name="name">analytic.account.tag.form</field>
        <field name="model">analytic.account.tag</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="color" widget="color_picker"/>
                        <field name="active"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_analytic_account_tag" model="ir.actions.act_window">
        <field name="name">Analytic Account Tags</field>
        <field name="res_model">analytic.account.tag</field>
        <field name="view_mode">tree,form</field>
    </record>
</odoo>
