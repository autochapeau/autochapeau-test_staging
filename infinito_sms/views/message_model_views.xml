<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record id="message_model_view_form" model="ir.ui.view">
        <field name="name">message.model.form</field>
        <field name="model">message.model</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <div class="alert alert-info" role="status">
                        <p>You can add dynamic content like the partner name in the message</p>
                        <p>The dynamic contents need to be like the following structure <code
                            >{o.attribute}</code> where <code>o</code>
                            stands for the object (e.g. <code>o.applicant_id.name</code>).
                        </p>
                    </div>
                    <group>
                        <field name="name" />
                        <field name="message" />
                        <field name="model_ids" widget="many2many_tags" options="{'no_create': True}" />
                    </group>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids" />
                    <field name="activity_ids" />
                    <field name="message_ids" />
                </div>
            </form>
        </field>
    </record>
    <record id="message_model_view_tree" model="ir.ui.view">
        <field name="name">message.model.tree</field>
        <field name="model">message.model</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name" />
            </tree>
        </field>
    </record>
    <record id="message_model_action" model="ir.actions.act_window">
        <field name="name">Message Models</field>
        <field name="res_model">message.model</field>
        <field name="view_mode">tree,form</field>
    </record>
    <menuitem
        name="SMS models"
        id="message_models_menu_technical"
        parent="mail.mail_menu_technical"
        action="message_model_action"
        sequence="55"
    />
</odoo>
