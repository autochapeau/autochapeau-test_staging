<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record id="portal_news_view_search" model="ir.ui.view">
        <field name="name">portal.news.search</field>
        <field name="model">portal.news</field>
        <field name="arch" type="xml">
            <search>
                <field name="name" />
                <filter string="Archived" name="inactive" domain="[('active', '=', False)]" />
            </search>
        </field>
    </record>

    <record id="portal_news_view_tree" model="ir.ui.view">
        <field name="name">portal.news.tree</field>
        <field name="model">portal.news</field>
        <field name="arch" type="xml">
            <tree>
                <field name="sequence" widget="handle" />
                <field name="name" />
                <field name="tag_ids" widget="many2many_tags" />
            </tree>
        </field>
    </record>

    <record id='portal_news_view_form' model='ir.ui.view'>
        <field name="name">portal.news.form</field>
        <field name="model">portal.news</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group>
                            <field name="name" />
                            <field name="summary" />
                            <field name="details" />
                            <field name="tag_ids" widget="many2many_tags" />
                            <field name="date" />
                        </group>
                        <group>
                            <field
                                name="image_1920"
                                widget='image'
                                options='{"zoom": true, "preview_image":"image_128"}'
                            />
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id='portal_news_action' model='ir.actions.act_window'>
        <field name="name">News</field>
        <field name="res_model">portal.news</field>
        <field name="view_mode">tree,form</field>
    </record>
    <menuitem id="portal_news_menu_root" name="News" parent="portal_content_menu_root" sequence="5" />
    <menuitem id="portal_news_menu" parent="portal_news_menu_root" action="portal_news_action" sequence="1" />

    <!--  News tags views -->
    <record id="portal_news_tag_view_tree" model="ir.ui.view">
        <field name="name">portal.news.tag.view.tree</field>
        <field name="model">portal.news.tag</field>
        <field name="arch" type="xml">
            <tree editable="bottom" sample="1">
                <field name="name" />
                <field name="color" widget="color_picker" />
            </tree>
        </field>
    </record>
    <record id="portal_news_tag_action" model="ir.actions.act_window">
        <field name="name">Tags</field>
        <field name="res_model">portal.news.tag</field>
        <field name="view_mode">tree</field>
    </record>

    <menuitem id="portal_tag_news_menu" parent="portal_news_menu_root" action="portal_news_tag_action" sequence="2" />

</odoo>
