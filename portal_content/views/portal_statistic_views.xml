<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record id="portal_statistic_view_search" model="ir.ui.view">
        <field name="name">portal.statistic.search</field>
        <field name="model">portal.statistic</field>
        <field name="arch" type="xml">
            <search>
                <field name="name" />
                <filter string="Archived" name="inactive" domain="[('active', '=', False)]" />
            </search>
        </field>
    </record>

    <record id="portal_statistic_view_tree" model="ir.ui.view">
        <field name="name">portal.statistic.tree</field>
        <field name="model">portal.statistic</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name" />
                <field name="value" />
            </tree>
        </field>
    </record>

    <record id='portal_statistic_view_form' model='ir.ui.view'>
        <field name="name">portal.statistic.form</field>
        <field name="model">portal.statistic</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group>
                            <field name="name" />
                            <field name="value" />
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id='portal_statistic_action' model='ir.actions.act_window'>
        <field name="name">Statistics</field>
        <field name="res_model">portal.statistic</field>
        <field name="view_mode">tree,form</field>
    </record>
    <menuitem
        id="portal_statistic_menu"
        parent="portal_content_menu_root"
        action="portal_statistic_action"
        sequence="4"
    />

</odoo>
