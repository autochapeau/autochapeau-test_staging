<?xml version="1.0" encoding="UTF-8" ?>
<odoo>

    <record id="portal_terms_conditions_view_tree" model="ir.ui.view">
        <field name="name">portal.terms.conditions.tree</field>
        <field name="model">portal.terms.conditions</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name" />
                <field name="summary" />
            </tree>
        </field>
    </record>

    <record id='portal_terms_conditions_view_form' model='ir.ui.view'>
        <field name="name">portal.terms.conditions.form</field>
        <field name="model">portal.terms.conditions</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group>
                            <field name="name" />
                            <field name="summary" />
                            <field name="details" />
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id='portal_terms_conditions_action' model='ir.actions.act_window'>
        <field name="name">Terms &amp; Conditions page</field>
        <field name="res_model">portal.terms.conditions</field>
        <field name="view_mode">tree,form</field>
    </record>
    <menuitem
        id="portal_terms_conditions_menu"
        parent="portal_content_menu_root"
        action="portal_terms_conditions_action"
        sequence="12"
    />

</odoo>
