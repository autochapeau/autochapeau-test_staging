<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record id="portal_warranty_view_search" model="ir.ui.view">
        <field name="name">portal.warranty.search</field>
        <field name="model">portal.warranty</field>
        <field name="arch" type="xml">
            <search>
                <field name="name" />
                <filter string="Archived" name="inactive" domain="[('active', '=', False)]" />
            </search>
        </field>
    </record>

    <record id="portal_warranty_view_tree" model="ir.ui.view">
        <field name="name">portal.warranty.tree</field>
        <field name="model">portal.warranty</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name" />
            </tree>
        </field>
    </record>

    <record id='portal_warranty_view_form' model='ir.ui.view'>
        <field name="name">portal.warranty.form</field>
        <field name="model">portal.warranty</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group>
                            <field name="name" />
                            <field name="details" />
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id='portal_warranty_action' model='ir.actions.act_window'>
        <field name="name">Warranty</field>
        <field name="res_model">portal.warranty</field>
        <field name="view_mode">tree,form</field>
    </record>
    <menuitem
        id="portal_warranty_menu"
        parent="portal_content_menu_root"
        action="portal_warranty_action"
        sequence="10"
    />

</odoo>
