<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record id="portal_testimony_view_search" model="ir.ui.view">
        <field name="name">portal.testimony.search</field>
        <field name="model">portal.testimony</field>
        <field name="arch" type="xml">
            <search>
                <field name="name" />
                <filter string="Archived" name="inactive" domain="[('active', '=', False)]" />
            </search>
        </field>
    </record>

    <record id="portal_testimony_view_tree" model="ir.ui.view">
        <field name="name">portal.testimony.tree</field>
        <field name="model">portal.testimony</field>
        <field name="arch" type="xml">
            <tree>
                <field name="sequence" widget="handle" />
                <field name="name" />
                <field name="summary" />
            </tree>
        </field>
    </record>

    <record id='portal_testimony_view_form' model='ir.ui.view'>
        <field name="name">portal.testimony.form</field>
        <field name="model">portal.testimony</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group>
                            <field name="name" />
                            <field name="summary" />
                            <field name="date" />
                        </group>
                        <group>
                            <field
                                name="image_1920"
                                widget='image'
                                options='{"zoom": true, "preview_image":"image_128"}'
                            />
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id='portal_testimony_action' model='ir.actions.act_window'>
        <field name="name">Testimonies</field>
        <field name="res_model">portal.testimony</field>
        <field name="view_mode">tree,form</field>
    </record>
    <menuitem
        id="portal_testimony_menu"
        parent="portal_content_menu_root"
        action="portal_testimony_action"
        sequence="4"
    />

</odoo>
