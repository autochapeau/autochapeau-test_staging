<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record id="portal_faq_view_search" model="ir.ui.view">
        <field name="name">portal.faq.search</field>
        <field name="model">portal.faq</field>
        <field name="arch" type="xml">
            <search>
                <field name="question" />
                <filter string="Archived" name="inactive" domain="[('active', '=', False)]" />
            </search>
        </field>
    </record>

    <record id="portal_faq_view_tree" model="ir.ui.view">
        <field name="name">portal.faq.tree</field>
        <field name="model">portal.faq</field>
        <field name="arch" type="xml">
            <tree>
                <field name="sequence" widget="handle" />
                <field name="question" />
                <field name="answer" />
            </tree>
        </field>
    </record>

    <record id='portal_faq_view_form' model='ir.ui.view'>
        <field name="name">portal.faq.form</field>
        <field name="model">portal.faq</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group>
                            <field name="question" />
                            <field name="answer" />
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id='portal_faq_action' model='ir.actions.act_window'>
        <field name="name">FAQ</field>
        <field name="res_model">portal.faq</field>
        <field name="view_mode">tree,form</field>
    </record>
    <menuitem id="portal_faq_menu" parent="portal_content_menu_root" action="portal_faq_action" sequence="7" />

</odoo>
