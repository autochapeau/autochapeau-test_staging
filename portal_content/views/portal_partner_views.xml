<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record id="portal_partner_view_search" model="ir.ui.view">
        <field name="name">portal.partner.search</field>
        <field name="model">portal.partner</field>
        <field name="arch" type="xml">
            <search>
                <field name="name" />
                <filter string="Archived" name="inactive" domain="[('active', '=', False)]" />
            </search>
        </field>
    </record>

    <record id="portal_partner_view_tree" model="ir.ui.view">
        <field name="name">portal.partner.tree</field>
        <field name="model">portal.partner</field>
        <field name="arch" type="xml">
            <tree>
                <field name="sequence" widget="handle" />
                <field name="name" />
            </tree>
        </field>
    </record>

    <record id='portal_partner_view_form' model='ir.ui.view'>
        <field name="name">portal.partner.form</field>
        <field name="model">portal.partner</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group>
                            <field name="name" />
                            <field name="summary" />
                        </group>
                        <group>
                            <field
                                name="image_1920"
                                string="Logo"
                                widget='image'
                                options='{"zoom": true, "preview_image":"image_128"}'
                            />
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id='portal_partner_action' model='ir.actions.act_window'>
        <field name="name">Partners list</field>
        <field name="res_model">portal.partner</field>
        <field name="view_mode">tree,form</field>
    </record>
    <menuitem id="portal_partner_menu" parent="portal_content_menu_root" action="portal_partner_action" sequence="1" />

</odoo>
