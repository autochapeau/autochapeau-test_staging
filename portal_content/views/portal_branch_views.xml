<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record id="portal_branch_view_search" model="ir.ui.view">
        <field name="name">portal.branch.search</field>
        <field name="model">portal.branch</field>
        <field name="arch" type="xml">
            <search>
                <field name="name" />
                <filter string="Archived" name="inactive" domain="[('active', '=', False)]" />
            </search>
        </field>
    </record>

    <record id="portal_branch_view_tree" model="ir.ui.view">
        <field name="name">portal.branch.tree</field>
        <field name="model">portal.branch</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name" />
            </tree>
        </field>
    </record>

    <record id='portal_branch_view_form' model='ir.ui.view'>
        <field name="name">portal.branch.form</field>
        <field name="model">portal.branch</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group>
                            <field name="name" />
                            <field name="address" />
                            <field name="map_url" widget="CopyClipboardChar" />
                        </group>
                        <group>
                            <field
                                name="image_1920"
                                widget='image'
                                options='{"zoom": true, "preview_image":"image_128"}'
                            />
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id='portal_branch_action' model='ir.actions.act_window'>
        <field name="name">Branches</field>
        <field name="res_model">portal.branch</field>
        <field name="view_mode">tree,form</field>
    </record>
    <menuitem id="portal_branch_menu" parent="portal_content_menu_root" action="portal_branch_action" sequence="9" />

</odoo>
