<?xml version="1.0" encoding="UTF-8" ?>
<odoo>

    <record id="portal_return_change_policy_view_tree" model="ir.ui.view">
        <field name="name">portal.return.change.policy.tree</field>
        <field name="model">portal.return.change.policy</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name" />
                <field name="summary" />
            </tree>
        </field>
    </record>

    <record id='portal_return_change_policy_view_form' model='ir.ui.view'>
        <field name="name">portal.return.change.policy.form</field>
        <field name="model">portal.return.change.policy</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group>
                            <field name="name" />
                            <field name="summary" />
                            <field name="details" />
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id='portal_return_change_policy_action' model='ir.actions.act_window'>
        <field name="name">Return And Change Policy</field>
        <field name="res_model">portal.return.change.policy</field>
        <field name="view_mode">tree,form</field>
    </record>
    <menuitem
        id="portal_return_change_policy_menu"
        name="Return And Change Policy"
        parent="portal_content_menu_root"
        action="portal_return_change_policy_action"
        sequence="13"
    />

</odoo>
