<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <record model="ir.module.category" id="module_category_work_orders">
        <field name="name">Work orders</field>
        <field name="sequence">45</field>
    </record>
    
    <!-- Groups-->
    <record id="group_workshop_employee" model="res.groups">
       <field name="name">Workshop Employee</field>
       <field name="category_id" ref="module_category_work_orders"/>
       <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
    </record>

    <record id="group_workshop_manager" model="res.groups">
       <field name="name">Workshop Manager</field>
       <field name="category_id" ref="module_category_work_orders"/>
       <field name="implied_ids" eval="[(4, ref('work_orders.group_workshop_employee'))]"/>
    </record>

    <record id="group_work_order_viewer_all" model="res.groups">
       <field name="name">View All Work Orders</field>
       <field name="category_id" ref="module_category_work_orders"/>
       <field name="implied_ids" eval="[(4, ref('work_orders.group_workshop_employee'))]"/>
    </record>

    <record id="group_quality_officer" model="res.groups">
       <field name="name">Quality Officer</field>
       <field name="category_id" ref="module_category_work_orders" />
       <field name="implied_ids" eval="[(4, ref('base.group_user'))]" />
    </record>

    <record id="group_quality_manager" model="res.groups">
        <field name="name">Quality Manager</field>
        <field name="category_id" ref="module_category_work_orders" />
        <field name="implied_ids" eval="[(4, ref('work_orders.group_quality_officer')), (4, ref('base.group_user'))]" />
    </record>

    <!--  Rules: multi-company rule removed temporarily to avoid SQL evaluation error during module load.
         Reintroduce a safe multi-company rule if needed after resolving res.company.name storage type. -->
    <record id="work_order_employee_service_rule" model="ir.rule">
        <field name="name">Work Order Service Branch Employee</field>
        <field name="model_id" ref="model_car_workorder_service" />
        <field name="domain_force">['&amp;',('staff_ids', 'in',user.employee_id.ids),'|',('workcenter_id.company_id', 'in', company_ids),('workcenter_id.company_id', '=', False)]</field>
         <field name="groups" eval="[(4, ref('work_orders.group_workshop_employee'))]" />
    </record>

    <record id="work_order_manager_service_rule" model="ir.rule">
        <field name="name">Work Order Service Branch Manager</field>
        <field name="model_id" ref="model_car_workorder_service" />
        <field name="domain_force">[(1,'=',1)]</field>
        <field name="groups" eval="[(4, ref('work_orders.group_workshop_manager')), (4, ref('work_orders.group_work_order_viewer_all'))]" />
    </record>

    <record id="work_order_employee_rule" model="ir.rule">
        <field name="name">Work Order Branch Employee </field>
        <field name="model_id" ref="model_car_work_order" />
        <field name="domain_force">[('branch_id', 'in', user.sudo().employee_ids.branch_id.ids)]</field>
        <field name="groups" eval="[(4, ref('work_orders.group_workshop_employee'))]" />
    </record>

    <record id="work_order_manager_rule" model="ir.rule">
        <field name="name">Work Order Branch Manager </field>
        <field name="model_id" ref="model_car_work_order" />
        <field name="domain_force">[(1,'=',1)]</field>
        <field name="groups" eval="[(4, ref('work_orders.group_workshop_manager')), (4, ref('work_orders.group_work_order_viewer_all'))]" />
    </record>
</odoo>
