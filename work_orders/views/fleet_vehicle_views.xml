<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record id="fleet_vehicle_view_form_inherit_workorder" model="ir.ui.view">
        <field name="name">fleet.vehicle.form.workorder</field>
        <field name="model">fleet.vehicle</field>
        <field name="inherit_id" ref="cars_management.fleet_vehicle_view_form" />
        <field name="arch" type="xml">
            <xpath expr="//div[@name='button_box']" position="inside">
                <button
                    name="action_view_workorders"
                    type="object"
                    class="oe_stat_button"
                    icon="fa-tasks"
                    help="Work orders"
                >
                    <field name="workorder_count" widget="statinfo" string="Work orders" />
                </button>
            </xpath>
        </field>
    </record>
</odoo>
