<?xml version="1.0" encoding="UTF-8" ?>
<templates>
    <t t-name="work_orders.WorkOrderDashboard">
        <div class="o_purchase_dashboard container-fluid py-4 border-bottom bg-view">
            <div class="row justify-content-between gap-3 gap-lg-0">
                <div class="col-12 col-lg-8 col-xl-5 col-xxl-5 flex-grow-1 flex-lg-grow-0 flex-shrink-0">
                    <div class="grid gap-4">
                        <div class="g-col-12 g-col-sm-10 grid gap-1">
                            <div
                                class="g-col-3 p-0"
                                t-on-click="setSearchContext"
                                title="Waiting"
                                filter_name="waiting_workorders"
                            >
                                <a
                                    href="#"
                                    class="btn btn-info w-100 h-100 border-0 rounded-0 text-capitalize text-break fw-normal"
                                >
                                    <div class="fs-2" t-out="workorderData['all_waiting']" />Waiting
                                </a>
                            </div>
                            <div
                                class="g-col-3 p-0"
                                t-on-click="setSearchContext"
                                title="Confirmed"
                                filter_name="confirmed_workorders"
                            >
                                <a
                                    href="#"
                                    class="btn btn-warning w-100 h-100 border-0 rounded-0 text-capitalize text-break fw-normal"
                                >
                                    <div class="fs-2" t-out="workorderData['all_progress']" />Progress
                                </a>
                            </div>
                            <div
                                class="g-col-3 p-0"
                                t-on-click="setSearchContext"
                                title="Done"
                                filter_name="done_workorders"
                            >
                                <a
                                    href="#"
                                    class="btn btn-success w-100 h-100 border-0 rounded-0 text-capitalize text-break fw-normal"
                                >
                                    <div class="fs-2" t-out="workorderData['all_done']" />Done
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </t>
</templates>
