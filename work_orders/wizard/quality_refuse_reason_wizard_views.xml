<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_quality_refuse_reason_wizard" model="ir.ui.view">
        <field name="name">quality.refuse.reason.wizard.form</field>
        <field name="model">quality.refuse.reason.wizard</field>
        <field name="arch" type="xml">
            <form string="Refusal Reason">
                <group>
                    <field name="reason" placeholder="Enter the reason for refusal..."/>
                </group>
                <footer>
                    <button string="Confirm" type="object" name="action_confirm" class="btn-primary"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
