<?xml version="1.0" encoding="UTF-8"?>

<odoo>
    <record id="sale_order_form_pricelist_product_domain"
            model="ir.ui.view">

        <field name="name">
            sale.order.form.pricelist.product.domain
        </field>

        <field name="model">sale.order</field>

        <field name="inherit_id" ref="sale.view_order_form"/>

        <field name="arch" type="xml">

            <xpath expr="//field[@name='order_line']//field[@name='product_template_id']"
                   position="before">

                <field name="restrict_pricelist_products"
                       column_invisible="1"/>

                <field name="allowed_pricelist_template_ids"
                       column_invisible="1"/>

            </xpath>

            <xpath expr="//field[@name='order_line']//field[@name='product_template_id']"
                   position="attributes">

                <attribute name="domain">
                    restrict_pricelist_products
                    and [('id', 'in', allowed_pricelist_template_ids)]
                    or [('sale_ok', '=', True)]
                </attribute>

            </xpath>

        </field>
    </record>
</odoo>