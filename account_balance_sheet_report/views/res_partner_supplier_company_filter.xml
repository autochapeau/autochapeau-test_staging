<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_res_partner_filter_supplier_company" model="ir.ui.view">
        <field name="name">res.partner.supplier.company.filter</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_res_partner_filter"/>
        <field name="arch" type="xml">
            <xpath expr="//filter[@name='supplier']" position="after">
                <!-- Filtre supprimé pour éviter le doublon dans la vue fournisseurs. Le filtre par défaut est géré via ir.filters. -->
            </xpath>
        </field>
    </record>
</odoo>
